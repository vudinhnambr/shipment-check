# Google Cloud service account used to read the two Excel/Sheets files from Google
# Drive. The files stay "Restricted" - only this one service account identity can
# read them. See README.md for how to create this and how to generate the base64
# value below (avoids the classic "broken PEM newlines" paste error).
GOOGLE_SERVICE_ACCOUNT_KEY_B64=paste_the_base64_string_here_no_quotes_no_line_breaks

# Google Drive file IDs of the two source files (the long id in the file's share/edit
# link, the part between /d/ and /edit). Open each link and check the title at the
# top of the page to make sure you copy the ID into the matching variable below.
DRIVE_SN_FILE_ID=put_check_sn_ring_from_sn_bearing_set_file_id_here
DRIVE_NCR_FILE_ID=put_inspection_notice_ncr_sr_tracking_file_id_here

# Optional: how long (seconds) to cache the downloaded/parsed data in memory before
# re-fetching from Drive on the next request. Default 300 (5 minutes).
CACHE_TTL_SECONDS=300
